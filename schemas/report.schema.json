            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning"
        },
        "requested_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requested Model"
        },
        "returned_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Returned Model"
        },
        "reviewed": {
          "const": false,
          "default": false,
          "title": "Reviewed",
          "type": "boolean"
        },
        "reviewed_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Reviewed At"
        },
        "status": {
          "const": "needs_review",
          "default": "needs_review",
          "title": "Status",
          "type": "string"
        },
        "suggested_severity_override": {
          "anyOf": [
            {
              "$ref": "#/$defs/Severity"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "usage": {
          "anyOf": [
            {
              "$ref": "#/$defs/TokenUsage"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "reviewed_at",
        "reason"
      ],
      "title": "DegradedReview",
      "type": "object"
    },
    "DynamicEvidence": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "dynamic",
          "default": "dynamic",
          "title": "Kind",
          "type": "string"
        },
        "logs": {
          "default": [],
