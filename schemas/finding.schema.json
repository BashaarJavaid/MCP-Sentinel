{
  "$defs": {
    "Confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "title": "Confidence",
      "type": "string"
    },
    "DegradedReview": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "evidence_refs": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/EvidenceReference"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Refs"
        },
        "latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latency Ms"
        },
        "mode": {
          "const": "degraded",
          "default": "degraded",
          "title": "Mode",
          "type": "string"
        },
        "probe_plan": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProbePlan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "reasoning": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning"
        },
        "requested_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requested Model"
        },
        "returned_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Returned Model"
        },
        "reviewed": {
          "const": false,
          "default": false,
          "title": "Reviewed",
          "type": "boolean"
        },
        "reviewed_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Reviewed At"
        },
        "status": {
          "const": "needs_review",
          "default": "needs_review",
          "title": "Status",
          "type": "string"
        },
        "suggested_severity_override": {
          "anyOf": [
            {
              "$ref": "#/$defs/Severity"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "usage": {
          "anyOf": [
            {
              "$ref": "#/$defs/TokenUsage"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "reviewed_at",
        "reason"
      ],
      "title": "DegradedReview",
      "type": "object"
    },
    "DynamicEvidence": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "dynamic",
          "default": "dynamic",
          "title": "Kind",
          "type": "string"
        },
        "logs": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Logs",
          "type": "array"
        },
        "probe_id": {
          "minLength": 1,
          "title": "Probe Id",
          "type": "string"
        },
        "request": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Request",
          "type": "object"
        },
        "response": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Response",
          "type": "object"
        }
      },
      "required": [
        "probe_id",
        "request",
        "response"
      ],
      "title": "DynamicEvidence",
      "type": "object"
    },
    "EvidenceReference": {
      "additionalProperties": false,
      "properties": {
        "claim": {
          "minLength": 1,
          "title": "Claim",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "range": {
          "$ref": "#/$defs/SourceRange"
        }
      },
      "required": [
        "path",
        "range",
        "claim"
      ],
      "title": "EvidenceReference",
      "type": "object"
    },
    "Exploitability": {
      "enum": [
        "confirmed",
        "likely",
        "theoretical"
      ],
      "title": "Exploitability",
      "type": "string"
    },
    "FileLocation": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "file",
          "default": "file",
          "title": "Kind",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "range": {
          "$ref": "#/$defs/SourceRange"
        }
      },
      "required": [
        "path",
        "range"
      ],
      "title": "FileLocation",
      "type": "object"
    },
    "FindingSource": {
      "enum": [
        "static",
        "dynamic"
      ],
      "title": "FindingSource",
      "type": "string"
    },
    "FindingStatus": {
      "enum": [
        "needs_review",
        "confirmed",
        "likely_false_positive",
        "suppressed"
      ],
      "title": "FindingStatus",
      "type": "string"
    },
    "Impact": {
      "enum": [
        "Critical",
        "High",
        "Medium",
        "Low",
        "Informational"
      ],
      "title": "Impact",
      "type": "string"
    },
    "JsonValue": {},
    "LiveReview": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence_refs": {
          "items": {
            "$ref": "#/$defs/EvidenceReference"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "latency_ms": {
          "minimum": 0,
          "title": "Latency Ms",
          "type": "integer"
        },
        "mode": {
          "const": "live",
          "default": "live",
          "title": "Mode",
          "type": "string"
        },
        "probe_plan": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProbePlan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        },
        "reasoning": {
          "minLength": 1,
          "title": "Reasoning",
          "type": "string"
        },
        "requested_model": {
          "minLength": 1,
          "title": "Requested Model",
          "type": "string"
        },
        "returned_model": {
          "minLength": 1,
          "title": "Returned Model",
          "type": "string"
        },
        "reviewed": {
          "const": true,
          "default": true,
          "title": "Reviewed",
          "type": "boolean"
        },
        "reviewed_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Reviewed At"
        },
        "status": {
          "$ref": "#/$defs/ReviewStatus"
        },
        "suggested_severity_override": {
          "anyOf": [
            {
              "$ref": "#/$defs/Severity"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "usage": {
          "$ref": "#/$defs/TokenUsage"
        }
      },
      "required": [
        "status",
        "requested_model",
        "returned_model",
        "confidence",
        "reasoning",
        "evidence_refs",
        "usage",
        "latency_ms",
        "reviewed_at"
      ],
      "title": "LiveReview",
      "type": "object"
    },
    "LogicalLocation": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "logical",
          "default": "logical",
          "title": "Kind",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "title": "LogicalLocation",
      "type": "object"
    },
    "NotReviewedReview": {
